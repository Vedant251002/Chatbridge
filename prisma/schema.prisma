generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Conversation {
  id             String    @id @default(uuid()) @db.Uuid
  phone          String    @db.VarChar(20)
  threadId       String    @map("thread_id")
  aiPaused       Boolean   @default(false) @map("ai_paused")
  takenOverBy    String?   @map("taken_over_by")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  messages       Message[]

  @@index([phone])
  @@index([lastActivityAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  sender         String
  message        String
  aiOutput       Json?        @map("ai_output")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

model BotConfig {
  id        String   @id @default("default")
  prompt    String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bot_configs")
}

model AllowedNumber {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @unique @db.VarChar(20)
  label     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("allowed_numbers")
}

enum KnowledgeStatus {
  pending
  processing
  ready
  failed

  @@map("knowledge_status")
}

enum KnowledgeSourceType {
  text
  markdown
  url

  @@map("knowledge_source_type")
}

model KnowledgeDocument {
  id          String              @id @default(uuid()) @db.Uuid
  title       String
  sourceType  KnowledgeSourceType @map("source_type")
  sourceUrl   String?             @map("source_url")
  sourceText  String              @map("source_text") @db.Text
  status      KnowledgeStatus     @default(pending)
  errorMsg    String?             @map("error_msg")
  chunkCount  Int                 @default(0) @map("chunk_count")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  chunks      KnowledgeChunk[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("knowledge_documents")
}

// Embedding column is created by raw SQL in the migration because Prisma
// doesn't natively understand the pgvector type. Queries that use it go
// through $queryRaw.
model KnowledgeChunk {
  id         String            @id @default(uuid()) @db.Uuid
  documentId String            @map("document_id") @db.Uuid
  ordinal    Int
  content    String            @db.Text
  tokenCount Int               @map("token_count")
  createdAt  DateTime          @default(now()) @map("created_at")
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("knowledge_chunks")
}
