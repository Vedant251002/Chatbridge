# Copy this to .env on the EC2 host and fill in real values.

# ─── Database ────────────────────────────────────────────────────────────────
# Used by the postgres service AND by the apps' DATABASE_URL.
POSTGRES_USER=whatsapp_ai
POSTGRES_PASSWORD=__set_a_long_random_secret__
POSTGRES_DB=whatsapp_ai

DATABASE_URL=postgresql://whatsapp_ai:__set_a_long_random_secret__@postgres:5432/whatsapp_ai

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── AI Provider ─────────────────────────────────────────────────────────────
AI_PROVIDER=xai
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-3

# ─── Embeddings ──────────────────────────────────────────────────────────────
EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
WHATSAPP_SESSION_DIR=./sessions

# ─── Public host + admin auth (used by Caddy) ────────────────────────────────
DOMAIN=bot.example.com
ADMIN_USER=admin
# Generate with:
#   docker run --rm caddy:2-alpine caddy hash-password
# Paste the resulting $2a$... hash here (escape any literal $ as $$ if using
# inline strings, but env_file values don't need escaping).
ADMIN_PASSWORD_HASH=
