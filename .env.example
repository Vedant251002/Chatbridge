# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/whatsapp_ai

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── AI Provider (chat completions) ──────────────────────────────────────────
# Options: xai | groq | mock
# xai  = xAI Grok (required by assessment — https://console.x.ai)
# groq = GroqCloud free tier alternative (https://console.groq.com)
# mock = local mock provider (offline dev only)
AI_PROVIDER=xai

# xAI Grok (primary — matches assessment PDF)
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-3

# GroqCloud (optional free-tier alternative — set AI_PROVIDER=groq to use)
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Embeddings (RAG) ────────────────────────────────────────────────────────
# Options: openai | mock
# openai = OpenAI embeddings API (text-embedding-3-small, 1536 dims)
# mock   = deterministic stub embeddings — works offline but not semantically useful
EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_SESSION_DIR=./sessions
