    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.27.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
